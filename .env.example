# AI Inference Platform — environment variable template
# Copy this file to .env and fill in real values. Never commit .env.
# All values here MUST remain empty. No secrets in this file.

# ── LiteLLM ──────────────────────────────────────────────────────────────────
LITELLM_MASTER_KEY=
LITELLM_SALT_KEY=

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=

# ── LLM provider API keys ────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
COHERE_API_KEY=

# ── Langfuse (obs profile) ───────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
# Langfuse server + worker — obs profile only
LANGFUSE_INIT_USER_EMAIL=
LANGFUSE_INIT_USER_PASSWORD=
NEXTAUTH_URL=
NEXTAUTH_SECRET=
SALT=
# Langfuse DB connection (separate from litellm DB)
# Format: postgresql://user:password@host:port/langfuse
LANGFUSE_DATABASE_URL=

# ── Phoenix Arize (obs profile) ───────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
# Phoenix DB connection
# Format: postgresql://user:password@host:port/phoenix
PHOENIX_SQL_DATABASE_URL=

# ── Keycloak ─────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=
KEYCLOAK_ADMIN_PASSWORD=

# ── HashiCorp Vault ──────────────────────────────────────────────────────────
VAULT_ROOT_TOKEN=
VAULT_ADDR=

# ── OPA ──────────────────────────────────────────────────────────────────────
OPA_API_KEY=

# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=
GRAFANA_ADMIN_PASSWORD=

# ── Kong ─────────────────────────────────────────────────────────────────────
# Smoke-test consumer API key — injected into Kong declarative config at startup.
# Use any non-empty string for local dev (e.g. a random UUID).
SMOKE_API_KEY=

# ── LiteLLM database connection ───────────────────────────────────────────────
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=
